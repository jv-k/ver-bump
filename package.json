{
  "name": "@jv-k/verbump",
  "version": "4.0.2",
  "description": "Release tool for any Git repo: reads your Conventional Commits to suggest a SemVer bump, then updates the changelog, tags, and pushes. Optional release-branch and PR workflows — no Node toolchain, just git + jq.",
  "author": "John Valai <git@jvk.to>",
  "homepage": "https://github.com/jv-k/VerBump",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jv-k/VerBump.git"
  },
  "license": "MIT",
  "bin": {
    "verbump": "verbump.sh"
  },
  "files": [
    "verbump.sh",
    "lib/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "./dev/sandbox.sh",
    "docs:dev": "pnpm --filter docs-site dev",
    "docs:build": "pnpm --filter docs-site build",
    "dev:dry": "./dev/sandbox.sh --dry-run",
    "release": "./verbump.sh --release -p origin && pnpm brew:bump",
    "bump-release": "./verbump.sh --patch -y --release -p origin && pnpm brew:bump",
    "brew:bump": "gh workflow run bump-formula.yml --repo jv-k/homebrew-tap",
    "tests:install": "./install_bats.sh",
    "tests:run": "./test/bats/bin/bats ./test/*.bats",
    "lint": "shellcheck -x -e SC1017 ./verbump.sh ./install.sh ./lib/*.sh",
    "screenshots": "./dev/screenshots.sh all",
    "screenshots:help": "./dev/screenshots.sh help",
    "screenshots:demo": "./dev/screenshots.sh demo",
    "prepublishOnly": "bash dev/prepublish-version-guard.sh"
  },
  "keywords": [
    "bash versioning",
    "versioning",
    "code versioning",
    "bumpversion",
    "verbump",
    "bumping",
    "versioning-workflow"
  ],
  "devDependencies": {
    "cz-conventional-changelog": "^3.3.0"
  }
}
